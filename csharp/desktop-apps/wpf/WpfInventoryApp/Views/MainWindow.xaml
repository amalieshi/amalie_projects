<Window x:Class="WpfInventoryApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:WpfInventoryApp.ViewModels"
        Title="WPF Inventory Management System"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#2C3E50"
                Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦"
                        FontSize="24"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Inventory Management System"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Content="🔄 Refresh"
                        Command="{Binding LoadProductsCommand}"
                        Margin="20,0,0,0"
                        Padding="10,5"
                        Background="#3498DB"
                        Foreground="White"
                        BorderBrush="Transparent"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1"
                Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Product List -->
            <GroupBox Grid.Column="0"
                    Header="Products"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Product Actions -->
                    <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                        <Button Content="➕ Add"
                                Command="{Binding AddProductCommand}"
                                Padding="10,5"
                                Margin="0,0,5,0"
                                Background="#27AE60"
                                Foreground="White"
                                BorderBrush="Transparent"/>
                        <Button Content="✏️ Edit"
                                Command="{Binding EditProductCommand}"
                                Padding="10,5"
                                Margin="0,0,5,0"
                                Background="#F39C12"
                                Foreground="White"
                                BorderBrush="Transparent"/>
                        <Button Content="🗑️ Delete"
                                Command="{Binding DeleteProductCommand}"
                                Padding="10,5"
                                Margin="0,0,5,0"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderBrush="Transparent"/>
                    </StackPanel>

                    <!-- Product DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F8F9FA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="SKU"
                                    Binding="{Binding SKU}"
                                    Width="100"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Quantity"
                                    Binding="{Binding Quantity}"
                                    Width="80"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price"
                                    Binding="{Binding Price, StringFormat=C}"
                                    Width="80"
                                    IsReadOnly="True"/>
                            <DataGridTextColumn Header="Created"
                                    Binding="{Binding CreatedAt, StringFormat=MM/dd/yyyy}"
                                    Width="100"
                                    IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                    Width="5"
                    Background="#BDC3C7"
                    HorizontalAlignment="Stretch"/>

            <!-- Product Form -->
            <GroupBox Grid.Column="2"
                    Header="{Binding FormTitle}"
                    Padding="10">
                <StackPanel>
                    <!-- Product Name -->
                    <Label Content="Product Name:"
                            FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentProduct.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                            Padding="5"/>

                    <!-- SKU -->
                    <Label Content="SKU:"
                            FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentProduct.SKU, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                            Padding="5"/>

                    <!-- Quantity -->
                    <Label Content="Quantity:"
                            FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentProduct.Quantity, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                            Padding="5"/>

                    <!-- Price -->
                    <Label Content="Price ($):"
                            FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentProduct.Price, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Margin="0,0,0,20"
                            Padding="5"/>

                    <!-- Form Actions -->
                    <StackPanel>
                        <!-- Add/Update Button -->
                        <Button Content="💾 Save"
                                Command="{Binding AddProductCommand}"
                                Padding="10,8"
                                Margin="0,0,0,5"
                                Background="#27AE60"
                                Foreground="White"
                                BorderBrush="Transparent">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}"
                                                Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="💾 Update"
                                Command="{Binding UpdateProductCommand}"
                                Padding="10,8"
                                Margin="0,0,0,5"
                                Background="#3498DB"
                                Foreground="White"
                                BorderBrush="Transparent">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}"
                                                Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Cancel Button (only in edit mode) -->
                        <Button Content="❌ Cancel"
                                Command="{Binding CancelEditCommand}"
                                Padding="10,8"
                                Margin="0,0,0,5"
                                Background="#95A5A6"
                                Foreground="White"
                                BorderBrush="Transparent">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}"
                                                Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Clear Button -->
                        <Button Content="🗑️ Clear"
                                Command="{Binding ClearFormCommand}"
                                Padding="10,8"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderBrush="Transparent">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}"
                                                Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2"
                Height="25">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total Products: "/>
                    <TextBlock Text="{Binding Products.Count}"
                            FontWeight="Bold"/>
                    <ProgressBar Width="100"
                                 Height="15"
                                 Margin="10,0,0,0"
                                 IsIndeterminate="{Binding IsLoading}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>